    "@react-pdf/renderer": "^4.3.2",
    "@trigger.dev/sdk": "^4.4.3",
    "axios": "^1.13.4",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-intl": "^4.8.2",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.8.0",
    "resend": "^6.9.1",
