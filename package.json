    "exceljs": "^4.4.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.4.3",
